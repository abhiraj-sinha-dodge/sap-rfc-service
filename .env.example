# RFC Service Configuration

# Server port
PORT=8090

# API Key (leave empty for no auth)
SAP_PROXY_API_KEY=

# RFC Destination: local
# Format: RFC_DEST_<name>_<property>
RFC_DEST_LOCAL_ASHOST=192.168.1.115
RFC_DEST_LOCAL_SYSNR=50
RFC_DEST_LOCAL_CLIENT=800
RFC_DEST_LOCAL_USER=ABAPID22
RFC_DEST_LOCAL_PASSWD=sap1234!
RFC_DEST_LOCAL_LANG=EN
RFC_DEST_LOCAL_POOL_CAPACITY=5
RFC_DEST_LOCAL_PEAK_LIMIT=10

# You can add more destinations:
# RFC_DEST_DEV_ASHOST=dev-sap.example.com
# RFC_DEST_DEV_SYSNR=00
# RFC_DEST_DEV_CLIENT=100
# RFC_DEST_DEV_USER=RFC_USER
# RFC_DEST_DEV_PASSWD=secret
# RFC_DEST_DEV_LANG=EN
